module Main exposing (main)

-- skynews — a HackerNews/Reddit-style demo built with Sky.Live and
-- Std.Ui. Demonstrates the layout DSL on a real interactive shape:
--
--   - Posts list (homepage) with up-vote per post
--   - Post detail page with nested comment thread (parent/child
--     relationships rendered with indentation)
--   - Comment up-vote
--   - Reply-to-comment compose
--   - Basic in-memory auth (sign in with any username/password
--     to exercise the form pattern; no DB)
--
-- All state lives in the Sky.Live session model — no DB, no
-- external services. This keeps the example focused on the view
-- layer (Std.Ui) and the TEA wiring (init/update/view), not on
-- persistence or auth correctness.
import Sky.Core.Prelude exposing (..)
import Sky.Core.List as List
import Sky.Core.Maybe as Maybe
import Sky.Core.String as String
import Std.Cmd as Cmd
import Std.Sub as Sub
import Std.Live exposing (app, route)
import Std.Ui as Ui
import Std.Ui exposing (Element)
import Std.Ui.Background as Background
import Std.Ui.Border as Border
import Std.Ui.Font as Font
import Std.Ui.Region as Region
import Std.Ui.Input as Input


-- Local typed-anchor for Std.Ui's `none` — Sky's canonicaliser
-- currently strips the type parameter when re-exporting it
-- cross-module, so we re-define it locally.
noneEl : Element msg
noneEl =
    Ui.none

-- ─── Domain types ────────────────────────────────────────────────
type alias Post =
    { id : Int
    , title : String
    , url : String
    , author : String
    , votes : Int
    , commentCount : Int
    }

type alias Comment =
    { id : Int
    , postId : Int
    , parentId : Int-- 0 = top-level (root) comment under the post
    , author : String
    , body : String
    , votes : Int
    }

type alias Session =
    { username : String }

type Page
    = HomePage
    | PostPage Int
    | LoginPage

type alias Model =
    { posts : List Post
    , comments : List Comment
    , currentPage : Page
    , session : Maybe Session
    , loginUser : String
    , loginPass : String
    , loginError : String
    , composeBody : String
    , replyTo : Int-- parentId for the next compose; 0 = top-level
    , nextCommentId : Int
    }


-- ─── Init ───────────────────────────────────────────────────────
init : a -> ( Model, Cmd Msg )
init _req =
    let
        seedPosts =
            [ Post
                  1
                  "Show SN: Sky.Ui — a typed elm-ui port for Sky.Live"
                  "https://github.com/anzellai/sky"
                  "alice"
                  142
                  8
            , Post
                  2
                  "Tiny CRDT primitives in 200 lines"
                  "https://example.com/crdt"
                  "bob"
                  87
                  12
            , Post
                  3
                  "Ask SN: Best resources for learning Hindley-Milner?"
                  "https://example.com/hm"
                  "carol"
                  56
                  23
            , Post
                  4
                  "Why server-driven UIs are having a moment"
                  "https://example.com/server-ui"
                  "dave"
                  41
                  5
            , Post
                  5
                  "Postgres tips that actually matter in production"
                  "https://example.com/pg-tips"
                  "eve"
                  38
                  4
            ]
        seedComments =
            [ Comment
                  101
