    in
        ( { posts = seedPosts
          , comments = seedComments
          , currentPage = HomePage
          , session = Nothing
          , loginError = ""
          , composeBody = ""
          , replyTo = 0
          , nextCommentId = 400
          }
        , Cmd.none
        )


-- ─── View dispatcher ─────────────────────────────────────────────
view : Model -> any
view model =
    Ui.layout
        []
        (Ui.column
            [ Ui.padding 24
            , Ui.spacing 24
            , Background.color (Ui.rgb 246 246 240)
            , Font.family "Verdana, Geneva, sans-serif"
            , Font.size 14
            , Font.color (Ui.rgb 33 33 33)
            ]
            [ topNav model, pageBody model, pageFooter ])


pageBody : Model -> Element Msg
pageBody model =
    case model.currentPage of

        HomePage ->
            postsListView model.session model.posts

        PostPage postId ->
            postDetailView model postId

        LoginPage ->
            loginView model


-- ─── App wiring ──────────────────────────────────────────────────
subscriptions : Model -> Sub.Sub Msg
subscriptions _ =
    Sub.none


main =
    app
        { init = init
        , update = update
        , view = view
        , subscriptions = subscriptions
        , routes = []
        , notFound = ()
        }
