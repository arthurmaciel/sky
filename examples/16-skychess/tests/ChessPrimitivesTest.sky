module ChessPrimitivesTest exposing (tests)

-- Primitive-level tests for the chess engine. These exercise the
-- smallest units (piece placement, board move, eval) in isolation
-- to catch regressions in the request→AI→move→response loop that
-- "AI plays dumb" shouldn't mask.
--
-- If these pass, the bug is further up the stack (move generation,
-- negamax scoring, or Sky.Live dispatch). If any fails, we've
-- caught the regression at its source.
import Sky.Core.Prelude exposing (..)
import Sky.Core.Dict as Dict
import Sky.Test as Test exposing (Test)
import Chess.Piece exposing (..)
import Chess.Board as Board
import Chess.Eval as Eval


-- Sanity: piece placement round-trips through Dict.
testSetAndGetPiece : Test
testSetAndGetPiece =
    Test.test
        "setPiece + getPiece round-trip"
        (\_ ->
            let
                piece = { kind = Queen, colour = White }
                board = Board.setPiece 27 piece Dict.empty
            in
                case Board.getPiece 27 board of

                    Just p ->
                        if p.kind == Queen && p.colour == White then
                            Test.pass

                        else
                            Test.fail "piece readback has wrong fields"

                    Nothing ->
                        Test.fail "piece disappeared after setPiece")


-- movePiece: White queen d1 (sq 59) → d4 (sq 35).
-- Post: empty at 59, queen at 35.
testMovePieceBasic : Test
testMovePieceBasic =
    Test.test
        "movePiece relocates the piece"
        (\_ ->
            let
                board =
                    Board.setPiece
                        59
                        { kind = Queen, colour = White }
                        Dict.empty
                after = Board.movePiece 59 35 board
                atFrom = Board.getPiece 59 after
                atTo = Board.getPiece 35 after
            in
                case atFrom of

                    Just _ ->
                        Test.fail "source square not cleared after move"

                    Nothing ->
                        case atTo of

                            Nothing ->
                                Test.fail "target square empty after move"

                            Just p ->
                                if p.kind == Queen && p.colour == White then
                                    Test.pass

                                else
                                    Test.fail "moved piece has wrong fields")


-- materialValue returns Queen > Rook > Bishop > Knight > Pawn > King.
-- If EnumTagIs codegen (from commit cca95cd) broke ADT matching for
-- zero-arg ctors, this test would fail.
testMaterialValues : Test
testMaterialValues =
    Test.test
        "materialValue returns the expected ranking"
        (\_ ->
            let
                q = materialValue Queen
                r = materialValue Rook
                b = materialValue Bishop
                n = materialValue Knight
                p = materialValue Pawn
                k = materialValue King
            in
                if q == 900 && r == 500 && b == 330 && n == 320 && p == 100 && k
                    == 0 then
                    Test.pass

                else
                    Test.fail
                        ("unexpected values Q=" ++ String.fromInt q ++ " R="
                            ++ String.fromInt r
                            ++ " B="
                            ++ String.fromInt b
                            ++ " N="
                            ++ String.fromInt n
                            ++ " P="
                            ++ String.fromInt p
                            ++ " K="
                            ++ String.fromInt k))


-- Eval.evaluate: board with a lone Black knight < 0 (Black has
-- material advantage; White is at material disadvantage).
-- If Eval ignores colour (treats Black pieces as White-positive) or
-- the piece-square table is mirror-broken, this would fail.
testEvalBlackKnightMaterial : Test
testEvalBlackKnightMaterial =
    Test.test
        "eval is negative for lone Black knight"
        (\_ ->
            let
                board =
                    Board.setPiece
                        27
                        { kind = Knight, colour = Black }
                        Dict.empty
                score = Eval.evaluate board
            in
                if score < 0 then
                    Test.pass

                else
                    Test.fail
                        ("expected negative for Black knight alone, got "
                            ++ String.fromInt score))


-- Symmetric check: White knight alone → positive.
testEvalWhiteKnightMaterial : Test
testEvalWhiteKnightMaterial =
    Test.test
        "eval is positive for lone White knight"
        (\_ ->
            let
                board =
                    Board.setPiece
                        27
                        { kind = Knight, colour = White }
                        Dict.empty
                score = Eval.evaluate board
            in
                if score > 0 then
                    Test.pass

                else
                    Test.fail
                        ("expected positive, got " ++ String.fromInt score))


tests : List Test
tests =
    [ testSetAndGetPiece
    , testMovePieceBasic
    , testMaterialValues
    , testEvalBlackKnightMaterial
    , testEvalWhiteKnightMaterial
    ]
