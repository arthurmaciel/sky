-- Evaluate position from white's perspective
-- Positive = white advantage, negative = black advantage
module Chess.Eval exposing (evaluate)

import Sky.Core.Prelude exposing (..)
import Sky.Core.Dict as Dict
import Sky.Core.List as List
import Sky.Core.Maybe as Maybe
import Chess.Piece exposing (..)
import Chess.Board as Board


evaluate : Dict Int Piece -> Int
evaluate board =
    List.foldl
        (\sq acc ->
            case Dict.get sq board of

                Just piece ->
                    acc + evaluatePieceAt sq piece

                Nothing ->
                    acc)
        0
        Board.allSquares


evaluatePieceAt : Int -> Piece -> Int
evaluatePieceAt sq piece =
    let
        material = materialValue piece.kind
        positional = pieceSquareValue piece.kind piece.colour sq
        total = material + positional
    in
        if piece.colour == White then
            total

        else
            0 - total


pieceSquareValue : Kind -> Colour -> Int -> Int
pieceSquareValue kind colour sq =
    let
        idx =
            if colour == White then
                sq

            else
                mirrorIndex sq
        table = getTable kind
    in
        tableValue table idx


mirrorIndex : Int -> Int
mirrorIndex sq =
    let
        row = sq // 8
        col = modBy 8 sq
    in
        (7 - row) * 8 + col


tableValue : List Int -> Int -> Int
tableValue table idx =
    Maybe.withDefault 0 (List.head (List.drop idx table))


getTable : Kind -> List Int
getTable kind =
    if kind == Pawn then
    -- Pawn: encourage central and advanced pawns
        pawnTable

    else if kind == Knight then
    -- Knight: encourage centre
        knightTable

    else if kind == Bishop then
    -- Bishop: encourage long diagonals
        bishopTable

    else if kind == Rook then
    -- Rook: encourage 7th rank and open files
        rookTable

    else if kind == Queen then
    -- Queen: slight central preference
        queenTable

    else if kind == King then
    -- King: encourage castled position (middlegame)
        kingTable

    else
        []


