module Main exposing (main)

import Sky.Core.Prelude exposing (..)
import Std.Log exposing (println)


type alias M =
    { i : Int, n : Int }


update : Int -> M -> M
update i m =
    -- n is Int, but we assign a String — HM must reject.
    { m | n = String.fromInt (i + 1) }


main =
    let
        result =
            update 1 { i = 0, n = 0 }
    in
    println (String.fromInt result.n)
