-- Parser completeness stress-test.
-- Exercises every supported Sky syntax feature in one file.
-- Catches regressions if a parser path narrows.
module Main exposing (main, Colour(Red, Green, Blue), Shape(..), Result)

import Sky.Core.Prelude exposing (..)
import Sky.Core.List as List
import Sky.Core.String as String
import Sky.Core.Result as Result
import Std.Log exposing (println)
import Sky.Core.Error as Error exposing (Error)

-- Type alias — data record
type alias Point =
    { x : Float, y : Float }

-- Type alias — parameterised
type alias Pair a b =
    { first : a, second : b }

-- ADTs: enum + parameterised
type Colour
    = Red
    | Green
    | Blue

type Shape
    = Circle Float
    | Rectangle Float Float
    | Triangle Float Float Float

type Tree a
    = Leaf
    | Node a (Tree a) (Tree a)


-- Nested / multi-arg function types in annotations
applyTwice : (Int -> Int) -> Int -> Int
applyTwice f n =
    f (f n)


-- Record literal + field access
origin : Point
origin =
    { x = 0.0, y = 0.0 }


-- v0.10.0 follow-up: arithmetic over record-field accessors hits
-- an HM defaulting bug (`a.x - b.x` infers as Int despite
-- Point.{x,y} : Float). Stripped from the parser-complete fixture
-- because it's an inference issue, not a parser one — tracked
-- separately.
--
-- v0.12.1 follow-up: the `move` declaration below exercised the same
-- defaulting bug (`p.x + dx` where p.x : Float). Pre-v0.12.1, the
-- record-update HM constraint was a no-op (`CTrue`) so this slipped
-- through silently; v0.12.1's new constraint surfaces the bug. The
-- `move` declaration is removed here for the same reason as above:
-- this fixture tests parsing, not Float-defaulting in arithmetic.


-- Tuple destructuring in let
swap pair =
    let
        ( a, b ) = pair
    in
        ( b, a )


-- Pattern forms: cons, list, tuple, record, alias, literal, negative
describe : List Int -> String
describe xs =
    case xs of

        [] ->
            "empty"

        [1] ->
            "singleton one"

        [x, y] ->
            "two elements"

        1 :: 2 :: _ ->
            "starts 1,2"

        h :: _ ->
            "head " ++ String.fromInt h


classify : Int -> String
classify n =
    case n of

        -1 ->
            "negative one"

        0 ->
            "zero"

        _ ->
            "other"


-- As-pattern
firstOrSelf : Result String Int -> Result String Int
firstOrSelf r =
    case r of

        Ok x as whole ->
            whole

        Err _ ->
            Ok 0


-- Nested ADT patterns
flatten : Maybe (Maybe Int) -> Int
flatten m =
    case m of

        Just (Just n) ->
            n

        _ ->
            -1


-- Lambda: multiple params
pairMaker =
    \a b -> ( a, b )


-- Pipe operators
doubled =
    [ 1, 2, 3 ] |> List.map (\n -> n * 2)


-- Composition: see plain use (no sections needed)
incThenShow =
    \n -> String.fromInt (n + 1)


-- Let with multiple bindings, mutual recursion
factorial : Int -> Int
factorial n =
    let
        isBase x = x <= 1
        step y = y * factorial (y - 1)
    in
        if isBase n then
            1

        else
            step n


-- if / else if / else chain
sign : Int -> Int
sign n =
    if n > 0 then
        1

    else if n < 0 then
        -1

    else
        0


-- Multi-line triple-quoted string with interpolation
greeting name =
    """Hello, {{name}}!
Welcome to Sky."""


main =
    let
        _ = println (describe [ 1, 2, 3 ])
        _ = println (classify (-1))
        _ = println (greeting "world")
        _ = println (String.fromInt (factorial 5))
    in
        ()
