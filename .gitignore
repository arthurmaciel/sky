*.bak
*.orig
*.rej
*.swp
*~

# Bootstrap build artifact (source is kept, binary is not)
bootstrap/app
sky-lang.org
dist-newstyle/
.cabal-sandbox/
cabal.sandbox.config
*.hi
*.o
*.dyn_hi
*.dyn_o
.ghc.environment.*
dist-newstyle/
.cabal-sandbox/
cabal.sandbox.config
*.hi
*.o
