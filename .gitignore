*.dyn_o
.ghc.environment.*

# Haskell compiler build
dist-newstyle/

# Legacy compilers
legacy-sky-compiler/bin/
legacy-sky-compiler/dist/
legacy-sky-compiler/sky-out/
legacy-sky-compiler/.skycache/
legacy-ts-compiler/node_modules/

# Runtime database files (from running examples at repo root)
*.db
*.db-shm
*.db-wal

# Stray SQLite files named literally "{}" when a test's connection
# string was the unsubstituted placeholder. Never source; never commit.
**/\{\}

# macOS
.DS_Store

# Legacy dist output (kept under legacy-ts-compiler/ if needed)
/dist/

# Embedded Sky stdlib materialised next to project src by the LSP
# (Sky.Build.Compile.writeStdlibTo) so goto-definition has a stable
# jump target — regenerated on each LSP build, not source code.
**/src/.sky-stdlib/

# Claude Code loop-pause marker (never commit; local-only pause signal)
.claude/allow-stop

# Nix build outputs
/result
/result-*

# direnv / nix-direnv cache
/.direnv/
/.envrc.local
sky.zip

# Local-only example verification — playwright recordings,
# screenshots, traces. Not source; per-developer; regenerated
# whenever scripts/verify-examples.sh is run.
_verify/
